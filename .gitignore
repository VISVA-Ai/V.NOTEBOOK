# ============================================
# V.NOTEBOOK — Git Ignore Rules
# ============================================

# ── Environment & Secrets ────────────────────
.env
.flaskenv
credentials.json
backend/credentials.json

# ── Google API Tokens ────────────────────────
**/gmail_token.json
**/calendar_token.json

# ── Data Directory (sessions, actions, logs) ─
data/
backend/data/
backend/core/data/

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Virtual Environments ─────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Distribution / Packaging ─────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Databases ────────────────────────────────
*.db
*.sqlite3

# ── IDEs ─────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Editor / Metadata ─────────────────────────
.antigravityignore
.gemini/
