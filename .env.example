# ============================================
# V.NOTEBOOK — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit the .env file to version control.
# ============================================

# ── Required: LLM Provider ──────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Additional Groq keys ──────────
# Multiple keys enable automatic rotation on rate limits.
# GROQ_API_KEY_2=your_second_key_here
# GROQ_API_KEY_3=your_third_key_here

# ── Optional: Fallback LLM Provider ─────────
# Used when all Groq keys are rate-limited.
# Get a key at https://openrouter.ai
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Optional: Web Search (Deep Research) ────
# TAVILY_API_KEY=your_tavily_key_here

# ── Google APIs (Gmail & Calendar) ──────────
# Download credentials.json from Google Cloud Console
# and place it in the project root.
# See README.md for full setup instructions.
GOOGLE_CREDENTIALS_PATH=credentials.json
